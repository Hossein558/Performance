<configuration>
  <packageSources>
    <!--
      Local source for licensed third-party packages.
      Place nsoftware.ipworksauth.24.0.9545.nupkg inside the LocalDependencies folder.
      Path is relative to this file, so it works the same on Windows and Linux.
    -->
    <add key="local-deps" value="./LocalDependencies" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
