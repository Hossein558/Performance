@page "/not-found"

<PageTitle>صفحه یافت نشد</PageTitle>

<div style="text-align:center; padding:4rem 2rem; color:var(--text-secondary);">
    <div style="font-size:4rem; margin-bottom:1rem;">🔍</div>
    <h1 style="font-size:1.4rem; font-weight:700; color:var(--primary); margin-bottom:0.5rem;">
        صفحه مورد نظر یافت نشد
    </h1>
    <p style="margin-bottom:1.5rem; font-size:0.9rem;">
        آدرس درخواستی وجود ندارد یا حذف شده است.
    </p>
    <a href="/" style="
        display:inline-block; padding:0.75rem 2rem;
        background:linear-gradient(135deg,var(--accent),var(--primary-light));
        color:#fff; border-radius:10px; font-weight:700; font-size:0.9rem;">
        بازگشت به داشبورد
    </a>
</div>