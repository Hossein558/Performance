@inherits LayoutComponentBase

<div class="app-shell">

    <AuthorizeView>
        <Authorized>
            <header class="app-header">
                <div class="header-brand">
                    <span class="header-icon">📊</span>
                    <span class="header-title">نظام ارزیابی عملکرد</span>
                </div>

                <nav class="header-nav">
                    <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                        🏠 داشبورد
                    </NavLink>
                    <NavLink href="/reports" class="nav-link">
                        📊 گزارش‌ها
                    </NavLink>
                </nav>

                <div class="header-user">
                    @{
                        var personnelCode = context.User.FindFirst("PersonnelCode")?.Value;
                        var fullName      = context.User.FindFirst("FullName")?.Value;
                    }
                    <div class="user-photo-placeholder" title="@fullName">
                        <img src="/api/avatar/@personnelCode"
                             class="header-avatar-photo"
                             alt="@fullName"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';" />
                        <span class="avatar-initials" style="display:none;">
                            @GetInitials(fullName)
                        </span>
                    </div>

                    <div class="user-info">
                        <span class="user-name">@context.User.FindFirst("FullName")?.Value</span>
                        <span class="user-code">کد: @context.User.FindFirst("PersonnelCode")?.Value</span>
                    </div>

                    <a href="/Account/Logout" class="btn-logout">خروج ↩</a>
                </div>
            </header>
        </Authorized>
    </AuthorizeView>

    <main class="app-main">
        @Body
    </main>

</div>

@code {
    private static string GetInitials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts[0][0].ToString();
    }
}
